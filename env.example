# ============================================================
#  project-root/.env
#  ⚠️  이 파일은 절대 git에 커밋하지 마세요!
#  .gitignore에 .env가 등록되어 있는지 반드시 확인하세요.
# ============================================================

# OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-여기에_실제_키를_입력하세요

# 소켓 서버 설정
SOCKET_HOST=0.0.0.0
SOCKET_PORT=9999

# 사용할 OpenAI 모델 (비용 효율: gpt-4o-mini 권장)
OPENAI_MODEL=gpt-4o-mini

# Gradio 대시보드 포트
GRADIO_PORT=7860

# ============================================================
#  [Kali] _01_kali_agent 설정
# ============================================================

# Windows 서버 IP (VMnet8 기준)
SERVER_IP=192.168.10.30

# 스니핑할 네트워크 인터페이스
INTERFACE=eth0

# BPF 필터 (기본: HTTP 포트 80)
BPF_FILTER=tcp port 80

# 디버그 출력 여부 (1=켜기, 0=끄기)
DEBUG=1
