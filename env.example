# ============================================================
#  project-root/.env
#  ⚠️  이 파일은 절대 git에 커밋하지 마세요!
#  .gitignore에 .env가 등록되어 있는지 반드시 확인하세요.
# ============================================================

# OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-여기에_실제_키를_입력하세요

# 소켓 서버 설정
SOCKET_HOST=0.0.0.0
SOCKET_PORT=9999

# 사용할 OpenAI 모델 (비용 효율: gpt-4o-mini 권장)
OPENAI_MODEL=gpt-4o-mini

# community.rules 파일 경로 (프로젝트 루트 기준)
COMMUNITY_RULES_PATH=./community.rules

# Gradio 대시보드 포트
GRADIO_PORT=7860
